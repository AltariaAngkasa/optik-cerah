# Connection string dari Neon / provider Postgres kamu
# Contoh: postgresql://user:password@ep-xxxx.aws.neon.tech/optikcerah?sslmode=require
DATABASE_URL=

# Ganti dengan string acak panjang & rahasia (buat sign token login)
JWT_SECRET=ganti-dengan-string-rahasia-yang-panjang

# Port untuk development lokal (tidak dipakai di Vercel)
PORT=3000
